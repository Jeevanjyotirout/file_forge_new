# Copy this file to .env and fill in values
# cp .env.example .env

APP_ENV=development
DEBUG=0
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]
REDIS_URL=redis://redis:6379/0
REDIS_RESULT_URL=redis://redis:6379/1
UPLOAD_DIR=/app/storage/uploads
OUTPUT_DIR=/app/storage/outputs
TEMP_DIR=/app/storage/temp
FILE_TTL_SECONDS=3600
MAX_UPLOAD_MB=500
DATABASE_URL=sqlite:////app/storage/fileforge.db
CELERY_TASK_SOFT_TIME_LIMIT=270
CELERY_TASK_TIME_LIMIT=300
CELERY_WORKER_MAX_TASKS=200
FLOWER_USER=admin
FLOWER_PASSWORD=fileforge
RATE_LIMIT_PER_MINUTE=60
OPENAI_API_KEY=
SENTRY_DSN=
